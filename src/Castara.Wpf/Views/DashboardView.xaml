<UserControl x:Class="Castara.Wpf.Views.DashboardView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <UniformGrid Columns="3">

        <materialDesign:Card Margin="10" Padding="16">
            <StackPanel>
                <TextBlock Text="Profiles" Opacity="0.7"/>
                <TextBlock Text="--" FontSize="28"/>
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Margin="10" Padding="16">
            <StackPanel>
                <TextBlock Text="Calculations" Opacity="0.7"/>
                <TextBlock Text="--" FontSize="28"/>
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Margin="10" Padding="16">
            <StackPanel>
                <TextBlock Text="Risk Flags" Opacity="0.7"/>
                <TextBlock Text="--" FontSize="28"/>
            </StackPanel>
        </materialDesign:Card>

    </UniformGrid>

</UserControl>