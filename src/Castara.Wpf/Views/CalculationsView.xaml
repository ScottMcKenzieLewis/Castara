<!-- ===============================
     Castara.Wpf.Views
     CalculationsView.xaml
     (refactored: tooltips next to labels, NO binding / UpdateSourceTrigger changes)
     =============================== -->

<UserControl x:Class="Castara.Wpf.Views.CalculationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:conv="clr-namespace:Castara.Wpf.Infrastructure.Converters"
             MinWidth="900"
             ToolTipService.IsEnabled="True"
             ToolTipService.InitialShowDelay="0"
             ToolTipService.ShowDuration="60000">

    <UserControl.Resources>
        <conv:RiskSeverityToBrushConverter x:Key="SeverityBrushConverter"/>
    </UserControl.Resources>

    <Grid Margin="8" Background="{DynamicResource MaterialDesignPaper}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="460"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- =========================
             INPUT CARD
             ========================= -->
        <materialDesign:Card Grid.Column="0"
                             Padding="20"
                             Margin="0,0,16,0">

            <StackPanel>
                <TextBlock Text="Inputs"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>

                <TextBlock Text="Composition and section parameters"
                           Opacity="0.7"
                           Margin="0,0,0,18"/>

                <!-- COMPOSITION -->
                <TextBlock Text="Composition"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Carbon (C)" FontSize="12" Opacity="0.7"/>
                            <Border Background="Transparent"
            Margin="6,0,0,0"
            VerticalAlignment="Center"
            ToolTipService.IsEnabled="True">
                                <Border.ToolTip>
                                    <ToolTip Content="{Binding CarbonTooltip}" />
                                </Border.ToolTip>
                                <materialDesign:PackIcon Kind="InformationOutline"
                                                     Width="14"
                                                     Height="14"
                                                     Margin="6,0,0,0"
                                                     Opacity="0.65"
                                                     VerticalAlignment="Center"
                                                     />
                            </Border>
                        </StackPanel>
                        <TextBox Text="{Binding Carbon, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,10"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Phosphorus (P)" FontSize="12" Opacity="0.7"/>
                            <Border Background="Transparent"
            Margin="6,0,0,0"
            VerticalAlignment="Center"
            ToolTipService.IsEnabled="True">
                                <Border.ToolTip>
                                    <ToolTip Content="{Binding PhosphorusTooltip}" />
                                </Border.ToolTip>
                                <materialDesign:PackIcon Kind="InformationOutline"
                                                     Width="14"
                                                     Height="14"
                                                     Margin="6,0,0,0"
                                                     Opacity="0.65"
                                                     VerticalAlignment="Center"
                                                     />
                            </Border>
                        </StackPanel>
                        <TextBox Text="{Binding Phosphorus, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,10"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Silicon (Si)" FontSize="12" Opacity="0.7"/>
                            <Border Background="Transparent"
Margin="6,0,0,0"
VerticalAlignment="Center"
ToolTipService.IsEnabled="True">
                                <Border.ToolTip>
                                    <ToolTip Content="{Binding SiliconTooltip}" />
                                </Border.ToolTip>
                                <materialDesign:PackIcon Kind="InformationOutline"
                                                     Width="14"
                                                     Height="14"
                                                     Margin="6,0,0,0"
                                                     Opacity="0.65"
                                                     VerticalAlignment="Center"
                                                     />
                            </Border>
                        </StackPanel>
                        <TextBox Text="{Binding Silicon, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,10"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Sulfur (S)" FontSize="12" Opacity="0.7"/>
                            <Border Background="Transparent"
Margin="6,0,0,0"
VerticalAlignment="Center"
ToolTipService.IsEnabled="True">
                                <Border.ToolTip>
                                    <ToolTip Content="{Binding SulfurTooltip}" />
                                </Border.ToolTip>
                                <materialDesign:PackIcon Kind="InformationOutline"
                                                     Width="14"
                                                     Height="14"
                                                     Margin="6,0,0,0"
                                                     Opacity="0.65"
                                                     VerticalAlignment="Center"
                                                     />
                            </Border>
                        </StackPanel>
                        <TextBox Text="{Binding Sulfur, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,10"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Manganese (Mn)" FontSize="12" Opacity="0.7"/>
                            <Border Background="Transparent"
Margin="6,0,0,0"
VerticalAlignment="Center"
ToolTipService.IsEnabled="True">
                                <Border.ToolTip>
                                    <ToolTip Content="{Binding ManganeseTooltip}" />
                                </Border.ToolTip>
                                <materialDesign:PackIcon Kind="InformationOutline"
                                                     Width="14"
                                                     Height="14"
                                                     Margin="6,0,0,0"
                                                     Opacity="0.65"
                                                     VerticalAlignment="Center"
                                                     />
                            </Border>
                        </StackPanel>
                        <TextBox Text="{Binding Manganese, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- SECTION -->
                <TextBlock Text="Section"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Thickness (mm)" FontSize="12" Opacity="0.7"/>
                            <Border Background="Transparent"
Margin="6,0,0,0"
VerticalAlignment="Center"
ToolTipService.IsEnabled="True">
                                <Border.ToolTip>
                                    <ToolTip Content="{Binding ThicknessTooltip}" />
                                </Border.ToolTip>
                                <materialDesign:PackIcon Kind="InformationOutline"
                                                     Width="14"
                                                     Height="14"
                                                     Margin="6,0,0,0"
                                                     Opacity="0.65"
                                                     VerticalAlignment="Center"
                                                     />
                            </Border>
                        </StackPanel>
                        <TextBox Text="{Binding ThicknessMm, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Cooling Rate (°C/s)" FontSize="12" Opacity="0.7"/>
                            <Border Background="Transparent"
Margin="6,0,0,0"
VerticalAlignment="Center"
ToolTipService.IsEnabled="True">
                                <Border.ToolTip>
                                    <ToolTip Content="{Binding CoolingRateTooltip}" />
                                </Border.ToolTip>
                                <materialDesign:PackIcon Kind="InformationOutline"
                                                     Width="14"
                                                     Height="14"
                                                     Margin="6,0,0,0"
                                                     Opacity="0.65"
                                                     VerticalAlignment="Center"
                                                     ToolTip="{Binding CoolingRateTooltip}"/>
                            </Border>
                        </StackPanel>
                        <TextBox Text="{Binding CoolingRateCPerSec, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="Calculate"
                            Command="{Binding CalculateCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{DynamicResource PrimaryHueDarkBrush}"
                            Foreground="{DynamicResource MaterialDesignBody}"
                            Margin="0,0,12,0"/>

                    <Button Content="Clear"
                            Command="{Binding ClearCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <!-- =========================
             RESULTS + CHARTS + FLAGS
             ========================= -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- KPIs -->
            <materialDesign:Card Grid.Row="0"
                                 Padding="18"
                                 UniformCornerRadius="10"
                                 Background="{DynamicResource MaterialDesignCardBackground}">
                <UniformGrid Columns="3">
                    <StackPanel>
                        <TextBlock Text="Carbon Eq." Opacity="0.7"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                        <TextBlock Text="{Binding CarbonEquivalentText}"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Graphitization" Opacity="0.7"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                        <TextBlock Text="{Binding GraphitizationScoreText}"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Hardness" Opacity="0.7"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                        <TextBlock Text="{Binding HardnessText}"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                    </StackPanel>
                </UniformGrid>
            </materialDesign:Card>

            <!-- CHARTS -->
            <materialDesign:Card Grid.Row="2"
                                 Padding="18"
                                 UniformCornerRadius="10"
                                 Background="{DynamicResource MaterialDesignCardBackground}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>

                    <!-- Composition bar chart -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Composition (wt%)"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   Margin="0,0,0,10"/>

                        <Border CornerRadius="10"
                                Padding="10"
                                Background="{DynamicResource MaterialDesignPaper}"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="1">
                            <oxy:PlotView Model="{Binding CompositionPlotModel}"
                                          Height="220"
                                          Background="Transparent"/>
                        </Border>
                    </StackPanel>

                    <!-- Gauges -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Gauges"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Graphitization donut -->
                            <Border CornerRadius="10"
                                    Padding="12"
                                    Background="{DynamicResource MaterialDesignPaper}"
                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <oxy:PlotView Model="{Binding GraphGaugeModel}"
                                                  Height="90"
                                                  Width="90"
                                                  Background="Transparent"/>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="Graphitization"
                                                   Opacity="0.7"
                                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                                        <TextBlock Text="{Binding GraphitizationScoreText}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Hardness donut -->
                            <Border Grid.Row="2"
                                    CornerRadius="10"
                                    Padding="12"
                                    Background="{DynamicResource MaterialDesignPaper}"
                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <oxy:PlotView Model="{Binding HardnessGaugeModel}"
                                                  Height="90"
                                                  Width="90"
                                                  Background="Transparent"/>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="Hardness"
                                                   Opacity="0.7"
                                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                                        <TextBlock Text="{Binding HardnessText}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!-- FLAGS -->
            <materialDesign:Card Grid.Row="4"
                                 Padding="18"
                                 UniformCornerRadius="10"
                                 Background="{DynamicResource MaterialDesignCardBackground}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Risk Flags"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource MaterialDesignBody}"/>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Flags}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10"
                                            Padding="14"
                                            Margin="0,0,0,10"
                                            Background="{DynamicResource MaterialDesignPaper}"
                                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border CornerRadius="10"
                                                    Padding="8,4"
                                                    Margin="0,0,12,0"
                                                    Background="{DynamicResource MaterialDesignCardBackground}"
                                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                                    BorderThickness="1">
                                                <TextBlock Text="{Binding Code}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MaterialDesignBody}"
                                                           Opacity="0.85"/>
                                            </Border>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MaterialDesignBody}"/>
                                                <TextBlock Text="{Binding Message}"
                                                           Opacity="0.8"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource MaterialDesignBody}"
                                                           Margin="0,6,0,0"/>
                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    CornerRadius="10"
                                                    Padding="10,4"
                                                    Margin="12,0,0,0"
                                                    Background="{DynamicResource MaterialDesignCardBackground}"
                                                    BorderBrush="{Binding Severity, Converter={StaticResource SeverityBrushConverter}}"
                                                    BorderThickness="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Circle"
                                                                             Width="10"
                                                                             Height="10"
                                                                             Margin="0,2,8,0"
                                                                             Foreground="{Binding Severity, Converter={StaticResource SeverityBrushConverter}}"/>
                                                    <TextBlock Text="{Binding Severity}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding Severity, Converter={StaticResource SeverityBrushConverter}}"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>