<UserControl x:Class="Castara.Wpf.Views.CalculationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:Castara.Wpf.Infrastructure.Converters"
             MinWidth="900">

	<!-- IMPORTANT CHANGE:
         Removed the SolidColorBrush resources that tried to set Color="{DynamicResource ...}"
         because MaterialDesignBackground/Divider are brushes, not colors. -->
	<UserControl.Resources>
		<conv:RiskSeverityToBrushConverter x:Key="SeverityBrushConverter"/>
	</UserControl.Resources>

	<!-- Use theme paper as the root so it flips correctly -->
	<Grid Margin="8"
          Background="{DynamicResource MaterialDesignPaper}">

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="460"/>
			<ColumnDefinition Width="16"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- =========================
             INPUT CARD
             ========================= -->
		<materialDesign:Card Grid.Column="0"
                             Padding="20"
                             Margin="0,0,16,0">

			<StackPanel>

				<TextBlock Text="Inputs"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>

				<TextBlock Text="Composition and section parameters"
                           Opacity="0.7"
                           Margin="0,0,0,18"/>

				<!-- =========================
                     COMPOSITION
                     ========================= -->
				<TextBlock Text="Composition"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

				<Grid Margin="0,0,0,16">

					<Grid.ColumnDefinitions>
						<ColumnDefinition/>
						<ColumnDefinition Width="16"/>
						<ColumnDefinition/>
					</Grid.ColumnDefinitions>

					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<!-- Carbon -->
					<StackPanel Grid.Row="0" Grid.Column="0">
						<TextBlock Text="Carbon (C)"
                                   FontSize="12"
                                   Opacity="0.7"/>
						<TextBox Text="{Binding Carbon}"
                                 Margin="0,2,0,10"/>
					</StackPanel>

					<!-- Phosphorus -->
					<StackPanel Grid.Row="0" Grid.Column="2">
						<TextBlock Text="Phosphorus (P)"
                                   FontSize="12"
                                   Opacity="0.7"/>
						<TextBox Text="{Binding Phosphorus}"
                                 Margin="0,2,0,10"/>
					</StackPanel>

					<!-- Silicon -->
					<StackPanel Grid.Row="1" Grid.Column="0">
						<TextBlock Text="Silicon (Si)"
                                   FontSize="12"
                                   Opacity="0.7"/>
						<TextBox Text="{Binding Silicon}"
                                 Margin="0,2,0,10"/>
					</StackPanel>

					<!-- Sulfur -->
					<StackPanel Grid.Row="1" Grid.Column="2">
						<TextBlock Text="Sulfur (S)"
                                   FontSize="12"
                                   Opacity="0.7"/>
						<TextBox Text="{Binding Sulfur}"
                                 Margin="0,2,0,10"/>
					</StackPanel>

					<!-- Manganese -->
					<StackPanel Grid.Row="2" Grid.Column="0">
						<TextBlock Text="Manganese (Mn)"
                                   FontSize="12"
                                   Opacity="0.7"/>
						<TextBox Text="{Binding Manganese}"
                                 Margin="0,2,0,0"/>
					</StackPanel>

				</Grid>

				<!-- =========================
                     SECTION
                     ========================= -->
				<TextBlock Text="Section"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

				<Grid Margin="0,0,0,20">

					<Grid.ColumnDefinitions>
						<ColumnDefinition/>
						<ColumnDefinition Width="16"/>
						<ColumnDefinition/>
					</Grid.ColumnDefinitions>

					<!-- Thickness -->
					<StackPanel Grid.Column="0">
						<TextBlock Text="Thickness (mm)"
                                   FontSize="12"
                                   Opacity="0.7"/>
						<TextBox Text="{Binding ThicknessMm}"
                                 Margin="0,2,0,0"/>
					</StackPanel>

					<!-- Cooling Rate -->
					<StackPanel Grid.Column="2">
						<TextBlock Text="Cooling Rate"
                                   FontSize="12"
                                   Opacity="0.7"/>
						<ComboBox SelectedItem="{Binding SelectedCoolingRate}"
                                  ItemsSource="{Binding CoolingRates}"
                                  Margin="0,2,0,0"/>
					</StackPanel>

				</Grid>

				<!-- Buttons -->
				<StackPanel Orientation="Horizontal">
					<Button Content="Calculate"
                            Command="{Binding CalculateCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="0,0,12,0"/>

					<Button Content="Clear"
                            Command="{Binding ClearCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
				</StackPanel>

				<TextBlock Text="Tip: Profiles can be added later to reuse common inputs."
                           Margin="0,12,0,0"
                           FontSize="12"
                           Opacity="0.6"/>

			</StackPanel>
		</materialDesign:Card>

		<!-- =========================
             RESULTS + FLAGS
             ========================= -->
		<Grid Grid.Column="2">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="16"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- KPIs -->
			<materialDesign:Card Grid.Row="0"
                                 Padding="18"
                                 UniformCornerRadius="10"
                                 Background="{DynamicResource MaterialDesignCardBackground}">

				<UniformGrid Columns="3">
					<StackPanel>
						<TextBlock Text="Carbon Eq." Opacity="0.7"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>
						<TextBlock Text="{Binding CarbonEquivalentText}"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>
					</StackPanel>

					<StackPanel>
						<TextBlock Text="Graphitization" Opacity="0.7"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>
						<TextBlock Text="{Binding GraphitizationScoreText}"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>
					</StackPanel>

					<StackPanel>
						<TextBlock Text="Hardness" Opacity="0.7"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>
						<TextBlock Text="{Binding HardnessText}"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>
					</StackPanel>
				</UniformGrid>
			</materialDesign:Card>

			<!-- Flags -->
			<materialDesign:Card Grid.Row="2"
                                 Padding="18"
                                 UniformCornerRadius="10"
                                 Background="{DynamicResource MaterialDesignCardBackground}">

				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="12"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<TextBlock Grid.Row="0"
                               Text="Risk Flags"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource MaterialDesignBody}"/>

					<ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">

						<ItemsControl ItemsSource="{Binding Flags}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border CornerRadius="10"
                                            Padding="14"
                                            Margin="0,0,0,10"
                                            Background="{DynamicResource MaterialDesignPaper}"
                                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                                            BorderThickness="1">

										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="Auto"/>
												<ColumnDefinition Width="*"/>
												<ColumnDefinition Width="Auto"/>
											</Grid.ColumnDefinitions>

											<!-- Code chip -->
											<Border CornerRadius="10"
                                                    Padding="8,4"
                                                    Margin="0,0,12,0"
                                                    Background="{DynamicResource MaterialDesignCardBackground}"
                                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                                    BorderThickness="1">

												<TextBlock Text="{Binding Code}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MaterialDesignBody}"
                                                           Opacity="0.85"/>
											</Border>

											<!-- Name + message -->
											<StackPanel Grid.Column="1">
												<TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MaterialDesignBody}"/>
												<TextBlock Text="{Binding Message}"
                                                           Opacity="0.8"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource MaterialDesignBody}"
                                                           Margin="0,6,0,0"/>
											</StackPanel>

											<!-- Severity badge -->
											<Border Grid.Column="2"
                                                    CornerRadius="10"
                                                    Padding="10,4"
                                                    Margin="12,0,0,0"
                                                    Background="{DynamicResource MaterialDesignCardBackground}"
                                                    BorderBrush="{Binding Severity, Converter={StaticResource SeverityBrushConverter}}"
                                                    BorderThickness="1">

												<StackPanel Orientation="Horizontal">
													<materialDesign:PackIcon Kind="Circle"
                                                                             Width="10"
                                                                             Height="10"
                                                                             Margin="0,2,8,0"
                                                                             Foreground="{Binding Severity, Converter={StaticResource SeverityBrushConverter}}"/>
													<TextBlock Text="{Binding Severity}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding Severity, Converter={StaticResource SeverityBrushConverter}}"/>
												</StackPanel>
											</Border>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

					</ScrollViewer>
				</Grid>
			</materialDesign:Card>
		</Grid>
	</Grid>
</UserControl>