<!-- ===============================
     Castara.Wpf.Views
     CalculationsView.xaml
     =============================== -->

<UserControl x:Class="Castara.Wpf.Views.CalculationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:conv="clr-namespace:Castara.Wpf.Infrastructure.Converters"
             MinWidth="900"
             ToolTipService.IsEnabled="True"
             ToolTipService.InitialShowDelay="0"
             ToolTipService.ShowDuration="60000">

    <UserControl.Resources>
        <conv:RiskSeverityToBrushConverter x:Key="SeverityBrushConverter"/>

        <!-- Common binding options for validated numeric TextBoxes -->
        <Style x:Key="ValidatedTextBinding" TargetType="{x:Type TextBox}">
            <Setter Property="TextBox.Text">
                <!-- Intentionally blank; each TextBox provides Path. -->
            </Setter>
        </Style>

        <!-- Shared label style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>

        <!-- Small info icon wrapper -->
        <Style x:Key="InfoIconContainer" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ToolTipService.IsEnabled" Value="True"/>
        </Style>

        <!-- Common TextBox binding settings via a reusable Binding -->
        <!-- Use it by copy/pasting the <Binding .../> body and only changing Path -->
        <!-- (WPF doesn't let us parameterize Binding.Path nicely without a custom markup extension.) -->
    </UserControl.Resources>

    <Grid Margin="8"
          Background="{DynamicResource MaterialDesignPaper}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="460"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- =========================
             INPUT CARD
             ========================= -->
        <materialDesign:Card Grid.Column="0"
                             Padding="20"
                             Margin="0,0,16,0">
            <StackPanel>
                <TextBlock Text="Inputs"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>

                <TextBlock Text="Composition and section parameters"
                           Opacity="0.7"
                           Margin="0,0,0,18"/>

                <!-- COMPOSITION -->
                <TextBlock Text="Composition"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Carbon -->
                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Carbon (C)"/>
                            <Border Style="{StaticResource InfoIconContainer}">
                                <Border.ToolTip>
                                    <ToolTip Content="{Binding CarbonTooltip}"/>
                                </Border.ToolTip>
                                <materialDesign:PackIcon Kind="InformationOutline"
                                                         Width="14" Height="14"
                                                         Opacity="0.65"
                                                         IsHitTestVisible="False"/>
                            </Border>
                        </StackPanel>

                        <TextBox Style="{StaticResource ValidatedTextBoxSafeTooltip}"
                                 Margin="0,2,0,10">
                            <TextBox.Text>
                                <Binding Path="CarbonText"
                                         UpdateSourceTrigger="PropertyChanged"
                                         ValidatesOnDataErrors="True"
                                         NotifyOnValidationError="True"
                                         Delay="250"
                                         FallbackValue="0"/>
                            </TextBox.Text>
                        </TextBox>
                    </StackPanel>

                    <!-- Phosphorus -->
                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Phosphorus (P)"/>
                            <Border Style="{StaticResource InfoIconContainer}">
                                <Border.ToolTip>
                                    <ToolTip Content="{Binding PhosphorusTooltip}"/>
                                </Border.ToolTip>
                                <materialDesign:PackIcon Kind="InformationOutline"
                                                         Width="14" Height="14"
                                                         Opacity="0.65"
                                                         IsHitTestVisible="False"/>
                            </Border>
                        </StackPanel>

                        <TextBox Style="{StaticResource ValidatedTextBoxSafeTooltip}"
                                 Margin="0,2,0,10">
                            <TextBox.Text>
                                <Binding Path="PhosphorusText"
                                         UpdateSourceTrigger="PropertyChanged"
                                         ValidatesOnDataErrors="True"
                                         NotifyOnValidationError="True"
                                         Delay="250"
                                         FallbackValue="0"/>
                            </TextBox.Text>
                        </TextBox>
                    </StackPanel>

                    <!-- Silicon -->
                    <StackPanel Grid.Row="1" Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Silicon (Si)"/>
                            <Border Style="{StaticResource InfoIconContainer}">
                                <Border.ToolTip>
                                    <ToolTip Content="{Binding SiliconTooltip}"/>
                                </Border.ToolTip>
                                <materialDesign:PackIcon Kind="InformationOutline"
                                                         Width="14" Height="14"
                                                         Opacity="0.65"
                                                         IsHitTestVisible="False"/>
                            </Border>
                        </StackPanel>

                        <TextBox Style="{StaticResource ValidatedTextBoxSafeTooltip}"
                                 Margin="0,2,0,10">
                            <TextBox.Text>
                                <Binding Path="SiliconText"
                                         UpdateSourceTrigger="PropertyChanged"
                                         ValidatesOnDataErrors="True"
                                         NotifyOnValidationError="True"
                                         Delay="250"
                                         FallbackValue="0"/>
                            </TextBox.Text>
                        </TextBox>
                    </StackPanel>

                    <!-- Sulfur -->
                    <StackPanel Grid.Row="1" Grid.Column="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Sulfur (S)"/>
                            <Border Style="{StaticResource InfoIconContainer}">
                                <Border.ToolTip>
                                    <ToolTip Content="{Binding SulfurTooltip}"/>
                                </Border.ToolTip>
                                <materialDesign:PackIcon Kind="InformationOutline"
                                                         Width="14" Height="14"
                                                         Opacity="0.65"
                                                         IsHitTestVisible="False"/>
                            </Border>
                        </StackPanel>

                        <TextBox Style="{StaticResource ValidatedTextBoxSafeTooltip}"
                                 Margin="0,2,0,10">
                            <TextBox.Text>
                                <Binding Path="SulfurText"
                                         UpdateSourceTrigger="PropertyChanged"
                                         ValidatesOnDataErrors="True"
                                         NotifyOnValidationError="True"
                                         Delay="250"
                                         FallbackValue="0"/>
                            </TextBox.Text>
                        </TextBox>
                    </StackPanel>

                    <!-- Manganese -->
                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Manganese (Mn)"/>
                            <Border Style="{StaticResource InfoIconContainer}">
                                <Border.ToolTip>
                                    <ToolTip Content="{Binding ManganeseTooltip}"/>
                                </Border.ToolTip>
                                <materialDesign:PackIcon Kind="InformationOutline"
                                                         Width="14" Height="14"
                                                         Opacity="0.65"
                                                         IsHitTestVisible="False"/>
                            </Border>
                        </StackPanel>

                        <TextBox Style="{StaticResource ValidatedTextBoxSafeTooltip}"
                                 Margin="0,2,0,0">
                            <TextBox.Text>
                                <Binding Path="ManganeseText"
                                         UpdateSourceTrigger="PropertyChanged"
                                         ValidatesOnDataErrors="True"
                                         NotifyOnValidationError="True"
                                         Delay="250"
                                         FallbackValue="0"/>
                            </TextBox.Text>
                        </TextBox>
                    </StackPanel>
                </Grid>

                <!-- SECTION -->
                <TextBlock Text="Section"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <!-- Thickness -->
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource FieldLabel}"
                                       Text="{Binding ThicknessLabel}"/>
                            <Border Style="{StaticResource InfoIconContainer}">
                                <Border.ToolTip>
                                    <ToolTip Content="{Binding ThicknessTooltip}"/>
                                </Border.ToolTip>
                                <materialDesign:PackIcon Kind="InformationOutline"
                                                         Width="14" Height="14"
                                                         Opacity="0.65"
                                                         IsHitTestVisible="False"/>
                            </Border>
                        </StackPanel>

                        <TextBox Style="{StaticResource ValidatedTextBoxSafeTooltip}"
                                 Margin="0,2,0,0">
                            <TextBox.Text>
                                <Binding Path="ThicknessText"
                                         UpdateSourceTrigger="PropertyChanged"
                                         ValidatesOnDataErrors="True"
                                         NotifyOnValidationError="True"
                                         Delay="250"
                                         FallbackValue="0"/>
                            </TextBox.Text>
                        </TextBox>
                    </StackPanel>

                    <!-- Cooling rate -->
                    <StackPanel Grid.Column="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource FieldLabel}"
                                       Text="{Binding CoolingRateLabel}"/>
                            <Border Style="{StaticResource InfoIconContainer}">
                                <Border.ToolTip>
                                    <ToolTip Content="{Binding CoolingRateTooltip}"/>
                                </Border.ToolTip>
                                <materialDesign:PackIcon Kind="InformationOutline"
                                                         Width="14" Height="14"
                                                         Opacity="0.65"
                                                         IsHitTestVisible="False"/>
                            </Border>
                        </StackPanel>

                        <TextBox Style="{StaticResource ValidatedTextBoxSafeTooltip}"
                                 Margin="0,2,0,0">
                            <TextBox.Text>
                                <Binding Path="CoolingRateText"
                                         UpdateSourceTrigger="PropertyChanged"
                                         ValidatesOnDataErrors="True"
                                         NotifyOnValidationError="True"
                                         Delay="250"
                                         FallbackValue="0"/>
                            </TextBox.Text>
                        </TextBox>
                    </StackPanel>
                </Grid>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="Calculate"
                            Command="{Binding CalculateCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{DynamicResource PrimaryHueDarkBrush}"
                            Foreground="{DynamicResource MaterialDesignBody}"
                            Margin="0,0,12,0"/>

                    <Button Content="Clear"
                            Command="{Binding ClearCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <!-- =========================
             RESULTS + CHARTS + FLAGS
             ========================= -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- KPIs -->
            <materialDesign:Card Grid.Row="0"
                                 Padding="18"
                                 UniformCornerRadius="10"
                                 Background="{DynamicResource MaterialDesignCardBackground}">
                <UniformGrid Columns="3">
                    <StackPanel>
                        <TextBlock Text="Carbon Eq." Opacity="0.7"/>
                        <TextBlock Text="{Binding CarbonEquivalentText}"
                                   FontSize="26"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Graphitization" Opacity="0.7"/>
                        <TextBlock Text="{Binding GraphitizationScoreText}"
                                   FontSize="26"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Hardness" Opacity="0.7"/>
                        <TextBlock Text="{Binding HardnessText}"
                                   FontSize="26"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </UniformGrid>
            </materialDesign:Card>

            <!-- MODEL INPUTS -->
            <materialDesign:Card Grid.Row="2"
                                 Padding="14"
                                 UniformCornerRadius="10"
                                 Background="{DynamicResource MaterialDesignCardBackground}">
                <StackPanel>
                    <TextBlock Text="Model Inputs"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <UniformGrid Columns="3">
                        <StackPanel>
                            <TextBlock Text="Carbon Eq." Opacity="0.7"/>
                            <TextBlock Text="{Binding CarbonEquivalentText}"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Cooling Factor" Opacity="0.7"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding CoolingFactorText}"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="  (" Opacity="0.8"/>
                                <TextBlock Text="{Binding CoolingRateText}" Opacity="0.8"/>
                                <TextBlock Text=" " Opacity="0.8"/>
                                <TextBlock Text="{Binding CoolingRateUnitSuffix}" Opacity="0.8"/>
                                <TextBlock Text=")" Opacity="0.8"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Thickness Factor" Opacity="0.7"/>
                            <TextBlock Text="{Binding ThicknessFactorText}"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </materialDesign:Card>

            <!-- CHARTS -->
            <materialDesign:Card Grid.Row="4"
                                 Padding="18"
                                 UniformCornerRadius="10"
                                 Background="{DynamicResource MaterialDesignCardBackground}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>

                    <!-- Composition bar chart -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Composition (wt%)"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <Border CornerRadius="10"
                                Padding="10"
                                Background="{DynamicResource MaterialDesignPaper}"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="1">
                            <oxy:PlotView Model="{Binding CompositionPlotModel}"
                                          Height="220"
                                          Background="Transparent"/>
                        </Border>
                    </StackPanel>

                    <!-- Gauges -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Gauges"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Graphitization donut -->
                            <Border CornerRadius="10"
                                    Padding="12"
                                    Background="{DynamicResource MaterialDesignPaper}"
                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <oxy:PlotView Model="{Binding GraphGaugeModel}"
                                                  Height="90"
                                                  Width="90"
                                                  Background="Transparent"/>

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Graphitization" Opacity="0.7"/>
                                        <TextBlock Text="{Binding GraphitizationScoreText}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Hardness donut -->
                            <Border Grid.Row="2"
                                    CornerRadius="10"
                                    Padding="12"
                                    Background="{DynamicResource MaterialDesignPaper}"
                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <oxy:PlotView Model="{Binding HardnessGaugeModel}"
                                                  Height="90"
                                                  Width="90"
                                                  Background="Transparent"/>

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Hardness" Opacity="0.7"/>
                                        <TextBlock Text="{Binding HardnessText}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!-- FLAGS -->
            <materialDesign:Card Grid.Row="6"
                                 Padding="18"
                                 UniformCornerRadius="10"
                                 Background="{DynamicResource MaterialDesignCardBackground}"
                                 VerticalAlignment="Stretch"
                                 HorizontalContentAlignment="Stretch"
                                 VerticalContentAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Risk Flags"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Flags}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="IsTabStop" Value="False"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10"
                                        Padding="14"
                                        Margin="0,0,0,10"
                                        Background="{DynamicResource MaterialDesignPaper}"
                                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border CornerRadius="10"
                                                Padding="8,4"
                                                Margin="0,0,12,0"
                                                Background="{DynamicResource MaterialDesignCardBackground}"
                                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding Code}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Opacity="0.85"/>
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Message}"
                                                       Opacity="0.8"
                                                       TextWrapping="Wrap"
                                                       Margin="0,6,0,0"/>
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                CornerRadius="10"
                                                Padding="10,4"
                                                Margin="12,0,0,0"
                                                Background="{DynamicResource MaterialDesignCardBackground}"
                                                BorderBrush="{Binding Severity, Converter={StaticResource SeverityBrushConverter}}"
                                                BorderThickness="1">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Circle"
                                                                         Width="10"
                                                                         Height="10"
                                                                         Margin="0,2,8,0"
                                                                         Foreground="{Binding Severity, Converter={StaticResource SeverityBrushConverter}}"/>
                                                <TextBlock Text="{Binding Severity}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding Severity, Converter={StaticResource SeverityBrushConverter}}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>