<UserControl x:Class="Castara.Wpf.Views.LogViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:components="clr-namespace:Castara.Wpf.Infrastructure.Components"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="1000">

    <Border Width="1000"
            MaxHeight="650"
            Padding="16"
            Background="{DynamicResource MaterialDesignPaper}"
            CornerRadius="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0"
                  Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         MinWidth="420"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Search logs (message/category/exception)"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                <ComboBox Grid.Column="1"
                          Margin="10,0,0,0"
                          MinWidth="170"
                          ItemsSource="{Binding LevelOptions}"
                          SelectedItem="{Binding SelectedLevelOption, Mode=TwoWay}"
                          DisplayMemberPath="Display"
                          ToolTip="Exact level (matches only that level)"
                          VerticalAlignment="Center"
                          Style="{StaticResource LogLevelComboBoxStyle}"/>

                <Button Grid.Column="2"
                        Margin="10,0,0,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding ClearCommand}">
                    Clear
                </Button>

                <Button Grid.Column="3"
                        Margin="10,0,0,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding CloseCommand}">
                    Close
                </Button>
            </Grid>

            <!-- Main -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="1.3*"/>
                </Grid.ColumnDefinitions>

                <!-- Logs grid -->
                <DataGrid Grid.Column="0"
                          ItemsSource="{Binding LogEntriesView}"
                          SelectedItem="{Binding SelectedLogEntry}"
                          components:DataGridSelectedItemsBehavior.SelectedItems="{Binding SelectedEntries}"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          RowHeight="34"
                          CanUserResizeRows="False"
                          Margin="0,0,12,0"
                          MaxHeight="520"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">

                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Copy selected"
                                      Command="{Binding CopySelectedCommand}" />
                            <MenuItem Header="Copy all (filtered)"
                                      Command="{Binding CopyAllCommand}" />
                            <Separator/>
                            <MenuItem Header="Select all"
                                      Command="ApplicationCommands.SelectAll"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.CommandBindings>
                        <CommandBinding Command="ApplicationCommands.SelectAll"
                                        Executed="SelectAll_Executed"/>
                    </DataGrid.CommandBindings>

                    <!-- Important: keep the DataGrid itself from forcing columns to fit -->
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Time"
                                            Width="170"
                                            Binding="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss.fff}}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="NoWrap"/>
                                    <Setter Property="TextTrimming" Value="None"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Level"
                                            Width="110"
                                            Binding="{Binding Level}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="NoWrap"/>
                                    <Setter Property="TextTrimming" Value="None"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Category"
                                            Width="260"
                                            Binding="{Binding Category}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="NoWrap"/>
                                    <Setter Property="TextTrimming" Value="None"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Message is allowed to be wider than the viewport -->
                        <DataGridTextColumn Header="Message"
                                            Width="900"
                                            Binding="{Binding Message}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="NoWrap"/>
                                    <Setter Property="TextTrimming" Value="None"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                    </DataGrid.Columns>
                </DataGrid>

                <!-- Details -->
                <Border Grid.Column="1"
                        Padding="12"
                        CornerRadius="8"
                        Background="{DynamicResource MaterialDesignPaper}"
                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                        BorderThickness="1">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Details"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Text="{Binding SelectedLogEntry.EventId, StringFormat=EventId: {0}}"
                                   Opacity="0.9"/>

                        <!-- Exception -->
                        <StackPanel Grid.Row="2"
                                    Margin="0,10,0,0">
                            <TextBlock Text="Exception"
                                       Foreground="{DynamicResource MaterialDesignBody}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>

                            <TextBox IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="120"
                                     Background="{DynamicResource MaterialDesignPaper}"
                                     Foreground="{DynamicResource MaterialDesignBody}"
                                     BorderBrush="{DynamicResource MaterialDesignDivider}"
                                     BorderThickness="1">
                                <TextBox.Text>
                                    <Binding Path="SelectedLogEntry.Exception"
                                             Mode="OneWay"
                                             TargetNullValue="—"/>
                                </TextBox.Text>
                            </TextBox>
                        </StackPanel>

                        <TabControl Grid.Row="3"
                                    Margin="0,10,0,0">

                            <TabItem Header="Properties">
                                <DataGrid ItemsSource="{Binding SelectedLogEntry.Properties}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          CellStyle="{StaticResource LogGridCellStyle}"
                                          RowHeight="32"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Key"
                                                            Width="160"
                                                            Binding="{Binding Key}"/>
                                        <DataGridTextColumn Header="Value"
                                                            Width="*"
                                                            Binding="{Binding Value}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>

                            <TabItem Header="Scopes">
                                <DataGrid ItemsSource="{Binding SelectedLogEntry.Scopes}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          CellStyle="{StaticResource LogGridCellStyle}"
                                          RowHeight="32"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Key"
                                                            Width="160"
                                                            Binding="{Binding Key}"/>
                                        <DataGridTextColumn Header="Value"
                                                            Width="*"
                                                            Binding="{Binding Value}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </Grid>

            <!-- Footer -->
            <TextBlock Grid.Row="2"
                       Margin="0,10,0,0"
                       Foreground="#9AA4AA"
                       Opacity="0.9"
                       Text="Tip: click a row to view exception + structured properties and scopes. Use Ctrl+Click for multi-select; right-click to copy."/>
        </Grid>
    </Border>
</UserControl>