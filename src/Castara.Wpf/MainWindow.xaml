<Window x:Class="Castara.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Castara"
        Width="1400"
        Height="900"
        Icon="pack://application:,,,/Resources/castara_logo.ico"
        WindowStartupLocation="CenterScreen"
        TextElement.FontFamily="Segoe UI Variable"
        TextElement.FontSize="14"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#1B1F22">

    <!-- Window Chrome -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="7"
                            CornerRadius="10"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>


    <Window.Resources>

        <!-- Min / Max button -->
        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Ultra-subtle hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg"
                                        Property="Background"
                                        Value="#168A8A8A"/>
                            </Trigger>

                            <!-- Gentle pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg"
                                        Property="Background"
                                        Value="#25909090"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button -->
        <Style x:Key="CaptionCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource CaptionButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg"
                                        Property="Background"
                                        Value="#E81123"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg"
                                        Property="Background"
                                        Value="#C50F1F"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- ==========================================================
             TITLE BAR
             ========================================================== -->
        <Border Grid.Row="0"
                Background="#1F262A"
                BorderBrush="#2E363B"
                BorderThickness="0,0,0,1">

            <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <Image Width="64"
                       Height="64"
                       Margin="0,0,0,0"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Source="pack://application:,,,/Resources/castara_logo_64.png"/>

                <!-- Title -->
                <TextBlock Grid.Column="1"
                           Text="CASTARA"
                           FontSize="17"
                           FontWeight="ExtraBold"
                           VerticalAlignment="Center"
                           Foreground="#F0F0F0"/>

                <!-- Caption Buttons -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">

                    <Button Style="{StaticResource CaptionButtonStyle}"
                            Click="Minimize_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <materialDesign:PackIcon Kind="WindowMinimize"
                                                 Width="18"
                                                 Height="18"
                                                 Foreground="#D0D0D0"/>
                    </Button>

                    <Button Style="{StaticResource CaptionButtonStyle}"
                            Click="MaxRestore_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <materialDesign:PackIcon x:Name="MaxRestoreIcon"
                                                 Kind="WindowMaximize"
                                                 Width="18"
                                                 Height="18"
                                                 Foreground="#D0D0D0"/>
                    </Button>

                    <Button Style="{StaticResource CaptionCloseButtonStyle}"
                            Click="Close_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <materialDesign:PackIcon Kind="WindowClose"
                                                 Width="18"
                                                 Height="18"
                                                 Foreground="#D0D0D0"/>
                    </Button>

                </StackPanel>

            </Grid>
        </Border>


        <!-- ==========================================================
             APP BODY
             ========================================================== -->
        <Grid Grid.Row="1">
            <materialDesign:DrawerHost>

                <!-- LEFT NAV -->
                <materialDesign:DrawerHost.LeftDrawerContent>
                    <DockPanel Width="260">

                        <StackPanel Margin="16">
                            <TextBlock Text="Castara"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Cast Iron Analysis"
                                       Opacity="0.7"/>
                        </StackPanel>

                        <Separator/>

                        <ListBox Margin="8"
                                 SelectedItem="{Binding SelectedNavItem}"
                                 Style="{StaticResource MaterialDesignNavigationListBox}">
                            <ListBoxItem Content="Dashboard" Tag="Dashboard"/>
                            <ListBoxItem Content="Composition Profiles" Tag="CompositionProfiles"/>
                            <ListBoxItem Content="Iron Calculations" Tag="IronCalculations"/>
                            <ListBoxItem Content="Quality Risks" Tag="QualityRisks"/>
                        </ListBox>

                    </DockPanel>
                </materialDesign:DrawerHost.LeftDrawerContent>


                <!-- MAIN -->
                <DockPanel LastChildFill="True">

                    <!-- TOP TOOLBAR -->
                    <materialDesign:ColorZone DockPanel.Dock="Top"
                                              Mode="PrimaryDark"
                                              Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Style="{StaticResource MaterialDesignToolButton}"
                                    Command="{x:Static materialDesign:DrawerHost.OpenDrawerCommand}">
                                <materialDesign:PackIcon Kind="Menu" Width="24" Height="24"/>
                            </Button>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding PageTitle}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="16,0,0,0"/>

                            <!-- Light / Dark -->
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">

                                <TextBlock Text="Light"
                                           Foreground="#F0F0F0"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           Opacity="0.9"/>

                                <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                              IsChecked="{Binding IsDarkMode}"
                                              VerticalAlignment="Center"/>

                                <TextBlock Text="Dark"
                                           Foreground="#F0F0F0"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Opacity="0.9"/>

                            </StackPanel>
                        </Grid>
                    </materialDesign:ColorZone>


                    <!-- STATUS BAR (anchored) -->
                    <Border DockPanel.Dock="Bottom"
                            Height="36"
                            Padding="12,6"
                            BorderBrush="#0B0E10"
                            BorderThickness="0,1,0,0">

                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#1A2024" Offset="0"/>
                                <GradientStop Color="#14181B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding StatusLeftText}"
                                       Foreground="#D6D6D6"
                                       VerticalAlignment="Center"/>

                            <Border Grid.Column="1"
                                    CornerRadius="14"
                                    Padding="10,4"
                                    Background="#0F1316"
                                    BorderBrush="#2A2A2A"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">

                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Circle"
                                                             Width="12"
                                                             Height="12"
                                                             Margin="0,0,8,0"
                                                             Foreground="{Binding StatusBrush}"/>
                                    <TextBlock Text="{Binding StatusRightText}"
                                               Foreground="#D6D6D6"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                            </Border>
                        </Grid>
                    </Border>


                    <!-- CONTENT -->
                    <Grid Margin="24">
                        <ContentControl Content="{Binding CurrentView}"/>
                    </Grid>

                </DockPanel>
            </materialDesign:DrawerHost>
        </Grid>

    </Grid>
</Window>