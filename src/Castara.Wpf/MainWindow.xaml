<!--
    MainWindow.xaml
    
    The main application window for Castara, providing a custom-styled chromeless window
    with integrated title bar controls, theme management, log viewing, and content hosting.
    
    Features:
    - Custom title bar with minimize, maximize/restore, and close buttons
    - Material Design theming with dark/light mode toggle
    - Unit system toggle (Standard/American)
    - Integrated log viewer with badge notification
    - Status bar with real-time feedback
    - Content area for hosting calculation views
    
    Architecture:
    - Uses WindowChrome for custom title bar while maintaining native window behavior
    - DialogHost pattern for modal log viewer overlay
    - Data binding to ShellViewModel for coordinated state management
    - Separate LogViewerViewModel for log viewer concerns (encapsulation)
-->

<Window x:Class="Castara.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:conv="clr-namespace:Castara.Wpf.Infrastructure.Converters"
        xmlns:views="clr-namespace:Castara.Wpf.Views"
        Title="Castara"
        Width="1200"
        Height="780"
        Icon="pack://application:,,,/Resources/castara_logo.ico"
        WindowStartupLocation="CenterScreen"
        TextElement.FontFamily="Segoe UI Variable"
        TextElement.FontSize="14"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#1B1F22">

    <!-- 
        WindowChrome Configuration
        
        Enables custom title bar styling while preserving native window behaviors:
        - CaptionHeight: Height of draggable title bar area (44px)
        - ResizeBorderThickness: Width of resize grip area around window edges (7px)
        - CornerRadius: Rounded corners for modern aesthetic (10px)
        - UseAeroCaptionButtons: False to use custom caption buttons
    -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="7"
                            CornerRadius="10"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- Built-in Converters -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- ========================================
             DEFAULT CONTROL STYLES
             
             Implicit styles that apply to all controls of the specified type.
             These ensure consistent theming across the application by binding
             to Material Design dynamic resources.
             ======================================== -->

        <Style TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="{DynamicResource MaterialDesignBody}"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground"
                    Value="{DynamicResource MaterialDesignBody}"/>
        </Style>

        <Style TargetType="TextBox"
               BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Foreground"
                    Value="{DynamicResource MaterialDesignBody}"/>
            <Setter Property="Background"
                    Value="{DynamicResource MaterialDesignPaper}"/>
            <Setter Property="Padding"
                    Value="10,6"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground"
                    Value="{DynamicResource MaterialDesignBody}"/>
            <Setter Property="Background"
                    Value="{DynamicResource MaterialDesignPaper}"/>
        </Style>

        <!-- ========================================
             CAPTION BUTTON BRUSHES
             
             Pre-defined brushes for caption button hover/pressed states.
             Note: Hex colors with alpha channel (#AARRGGBB format) cannot
             be used directly in style triggers, so they're defined as
             SolidColorBrush resources.
             ======================================== -->

        <!-- Standard caption buttons (minimize, maximize/restore) -->
        <SolidColorBrush x:Key="CaptionHoverBrush"
                         Color="#268A8A8A"/>
        <SolidColorBrush x:Key="CaptionPressedBrush"
                         Color="#30909090"/>

        <!-- Close button (Windows-style red) -->
        <SolidColorBrush x:Key="CaptionCloseHoverBrush"
                         Color="#E81123"/>
        <SolidColorBrush x:Key="CaptionClosePressedBrush"
                         Color="#C50F1F"/>

        <!-- ========================================
             CAPTION BUTTON STYLES
             
             Custom button styles for the title bar caption buttons.
             - Arrow cursor (not hand) for consistency with native windows
             - Transparent background with hover/pressed overlays
             - Fixed 44x44 size matching CaptionHeight
             - IsHitTestVisibleInChrome required for WindowChrome interaction
             ======================================== -->

        <!-- Base style for minimize and maximize/restore buttons -->
        <Style x:Key="CaptionButtonStyle"
               TargetType="Button">
            <Setter Property="Cursor"
                    Value="Arrow"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Width"
                    Value="44"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Center"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="FocusVisualStyle"
                    Value="{x:Null}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bg"
                                        Property="Background"
                                        Value="{StaticResource CaptionHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bg"
                                        Property="Background"
                                        Value="{StaticResource CaptionPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Opacity"
                                        Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button style with red hover state -->
        <Style x:Key="CaptionCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource CaptionButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bg"
                                        Property="Background"
                                        Value="{StaticResource CaptionCloseHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bg"
                                        Property="Background"
                                        Value="{StaticResource CaptionClosePressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Opacity"
                                        Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ========================================
         MAIN LAYOUT WITH DIALOG HOST
         
         DialogHost wrapper enables modal overlay for the log viewer.
         IsOpen binding controls visibility through LogViewerViewModel.IsOpen property.
         ======================================== -->

    <materialDesign:DialogHost IsOpen="{Binding LogViewerViewModel.IsOpen}">

        <!-- ========================================
             PRIMARY WINDOW GRID
             
             Four-row layout:
             1. Custom title bar (44px fixed)
             2. Toolbar with theme/units toggles (auto-sized)
             3. Main content area (star-sized, fills remaining space)
             4. Status bar (36px fixed)
             ======================================== -->

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- ========================================
                 TITLE BAR
                 
                 Custom title bar with:
                 - Application logo and branding
                 - Window caption buttons (minimize, maximize/restore, close)
                 - Drag-to-move functionality via MouseLeftButtonDown
                 - Double-click-to-maximize handled in code-behind
                 ======================================== -->
            <Border Grid.Row="0"
                    Background="#1F262A"
                    BorderBrush="#2E363B"
                    BorderThickness="0,0,0,1">

                <!-- Entire grid is draggable; double-click maximizes -->
                <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Application logo -->
                    <Image Width="64"
                           Height="64"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Source="pack://application:,,,/Resources/castara_logo_64.png"/>

                    <!-- Application title -->
                    <TextBlock Grid.Column="1"
                               Text="CASTARA"
                               FontSize="17"
                               FontWeight="ExtraBold"
                               VerticalAlignment="Center"
                               Foreground="#F0F0F0"/>

                    <!-- Caption buttons (minimize, maximize/restore, close) -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                MouseLeftButtonDown="CaptionButtons_MouseLeftButtonDown">

                        <!-- Minimize button -->
                        <Button Style="{StaticResource CaptionButtonStyle}"
                                Click="Minimize_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                ToolTip="Minimize">
                            <materialDesign:PackIcon Kind="WindowMinimize"
                                                     Width="18"
                                                     Height="18"
                                                     Foreground="#D0D0D0"/>
                        </Button>

                        <!-- Maximize/Restore button (icon changes in code-behind) -->
                        <Button Style="{StaticResource CaptionButtonStyle}"
                                Click="MaxRestore_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                ToolTip="Maximize">
                            <materialDesign:PackIcon x:Name="MaxRestoreIcon"
                                                     Kind="WindowMaximize"
                                                     Width="18"
                                                     Height="18"
                                                     Foreground="#D0D0D0"/>
                        </Button>

                        <!-- Close button (red hover state) -->
                        <Button Style="{StaticResource CaptionCloseButtonStyle}"
                                Click="Close_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                ToolTip="Close">
                            <materialDesign:PackIcon Kind="WindowClose"
                                                     Width="18"
                                                     Height="18"
                                                     Foreground="#D0D0D0"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ========================================
                 TOP TOOLBAR
                 
                 Contains application-level controls:
                 - Workbench title
                 - Units toggle (Standard/American) with animated border
                 - Theme toggle (Light/Dark)
                 
                 Both toggles use Material Design switch style for consistency.
                 ======================================== -->
            <materialDesign:ColorZone Grid.Row="1"
                                      Mode="PrimaryDark"
                                      Padding="16">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Section title -->
                    <TextBlock Text="Workbench"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Opacity="0.9"/>

                    <!-- Toggles container -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <!-- ========================================
                             UNITS TOGGLE
                             
                             Animated border that changes color when American Standard is active.
                             Uses ColorAnimation on SolidColorBrush.Color property for smooth transition.
                             Icon provides visual context for the units setting.
                             ======================================== -->
                        <Border CornerRadius="18"
                                Padding="14,6"
                                Margin="0,0,18,0"
                                Background="#0F1316"
                                BorderThickness="1">

                            <!-- SolidColorBrush required for ColorAnimation target -->
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#2A2A2A"/>
                            </Border.BorderBrush>

                            <!-- Animated border color on toggle state change -->
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <!-- Blue border when American Standard is enabled -->
                                        <DataTrigger Binding="{Binding IsAmericanStandard}"
                                                     Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                                        To="#4A90E2"
                                                                        Duration="0:0:0.18"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                                        To="#2A2A2A"
                                                                        Duration="0:0:0.18"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <!-- Units toggle content -->
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">

                                <!-- Ruler icon for visual context -->
                                <materialDesign:PackIcon Kind="Ruler"
                                                         Width="16"
                                                         Height="16"
                                                         Foreground="#D6D6D6"
                                                         Margin="0,0,8,0"
                                                         VerticalAlignment="Center"/>

                                <TextBlock Text="Units"
                                           FontWeight="SemiBold"
                                           Foreground="#D6D6D6"
                                           Margin="0,0,14,0"
                                           VerticalAlignment="Center"/>

                                <TextBlock Text="Standard"
                                           Foreground="#F0F0F0"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           Opacity="0.9"/>

                                <!-- Toggle switch bound to view model -->
                                <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                              IsChecked="{Binding IsAmericanStandard}"
                                              VerticalAlignment="Center"
                                              ToolTip="Switch between Standard and American Standard units"/>

                                <TextBlock Text="American"
                                           Foreground="#F0F0F0"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Opacity="0.9"/>
                            </StackPanel>
                        </Border>

                        <!-- ========================================
                             THEME TOGGLE
                             
                             Simple toggle between Light and Dark themes.
                             Coordinates theme changes across Material Design components
                             and OxyPlot charts through ShellViewModel.
                             ======================================== -->
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <TextBlock Text="Light"
                                       Foreground="#F0F0F0"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Opacity="0.9"/>

                            <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          IsChecked="{Binding IsDarkMode}"
                                          VerticalAlignment="Center"
                                          ToolTip="Switch between light and dark theme"/>

                            <TextBlock Text="Dark"
                                       Foreground="#F0F0F0"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Opacity="0.9"/>
                        </StackPanel>

                    </StackPanel>
                </Grid>
            </materialDesign:ColorZone>

            <!-- ========================================
                 MAIN CONTENT AREA
                 
                 Hosts the current view through ContentControl data binding.
                 CurrentViewModel property contains the active view model instance
                 (typically CalculationsViewModel).
                 
                 HorizontalContentAlignment/VerticalContentAlignment set to Stretch
                 to ensure content fills the available space.
                 ======================================== -->
            <Grid Grid.Row="2"
                  Margin="20">
                <ContentControl Content="{Binding CurrentViewModel}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"/>
            </Grid>

            <!-- ========================================
                 STATUS BAR
                 
                 Displays application status with:
                 - Status message on the left (e.g., "Ready", "Calculated", "Error")
                 - Status indicator on the right with color-coded circle
                 - Log viewer button with badge showing log entry count
                 
                 Status colors follow iOS/macOS conventions:
                 - Green (#35C759) for Ok
                 - Yellow (#FFCC00) for Warning
                 - Red (#FF3B30) for Error
                 ======================================== -->
            <Border Grid.Row="3"
                    Height="36"
                    Padding="12,6"
                    BorderBrush="#0B0E10"
                    BorderThickness="0,1,0,0">

                <!-- Subtle gradient background -->
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="0,1">
                        <GradientStop Color="#1A2024"
                                      Offset="0"/>
                        <GradientStop Color="#14181B"
                                      Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left-side status message (bound to ShellViewModel) -->
                    <TextBlock Text="{Binding StatusLeftText}"
                               Foreground="#D6D6D6"
                               VerticalAlignment="Center"/>

                    <!-- Right-side status indicator and log button -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <!-- Status indicator with colored circle (bound to ShellViewModel) -->
                        <Border CornerRadius="14"
                                Padding="10,4"
                                Background="#0F1316"
                                BorderBrush="#2A2A2A"
                                BorderThickness="1"
                                VerticalAlignment="Center">

                            <StackPanel Orientation="Horizontal">
                                <!-- Color-coded circle (bound to StatusBrush) -->
                                <materialDesign:PackIcon Kind="Circle"
                                                         Width="12"
                                                         Height="12"
                                                         Margin="0,0,8,0"
                                                         Foreground="{Binding StatusBrush}"/>

                                <!-- Status detail text -->
                                <TextBlock Text="{Binding StatusRightText}"
                                           Foreground="#D6D6D6"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- ========================================
                             LOG VIEWER BUTTON WITH BADGE
                             
                             DataContext scoped to LogViewerViewModel for encapsulation.
                             Binds to ShowCommand, HasLogs, and LogCount properties.
                             Badge appears when logs are present with entry count.
                             ======================================== -->
                        <Grid Margin="10,0,0,0"
                              VerticalAlignment="Center"
                              DataContext="{Binding LogViewerViewModel}">

                            <!-- Button to open log viewer -->
                            <Button Width="34"
                                    Height="28"
                                    ToolTip="View logs"
                                    Command="{Binding ShowCommand}"
                                    Style="{StaticResource MaterialDesignToolButton}">
                                <materialDesign:PackIcon Kind="FileDocumentOutline"
                                                         Width="18"
                                                         Height="18"
                                                         Foreground="#D6D6D6"/>
                            </Button>

                            <!-- Notification badge (visible when HasLogs is true) -->
                            <Border Width="18"
                                    Height="18"
                                    CornerRadius="9"
                                    Background="#E81123"
                                    BorderBrush="#0F1316"
                                    BorderThickness="2"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,-6,-6,0"
                                    Visibility="{Binding HasLogs, Converter={StaticResource BooleanToVisibilityConverter}}">

                                <!-- Log entry count -->
                                <TextBlock Text="{Binding LogCount}"
                                           Foreground="#FFFFFF"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ========================================
             LOG VIEWER DIALOG CONTENT
             
             Modal overlay dialog for viewing application logs.
             Hosted within DialogHost, visibility controlled by LogViewerViewModel.IsOpen.
             DataContext set to LogViewerViewModel for log management and filtering.
             ======================================== -->
        <materialDesign:DialogHost.DialogContent>
            <views:LogViewerView DataContext="{Binding LogViewerViewModel}"/>
        </materialDesign:DialogHost.DialogContent>

    </materialDesign:DialogHost>
</Window>