<Window x:Class="Castara.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Castara"
        Width="1400"
        Height="900"
        Icon="pack://application:,,,/Resources/castara_logo.ico"
        WindowStartupLocation="CenterScreen"
        TextElement.FontFamily="Segoe UI Variable"
        TextElement.FontSize="14"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#1B1F22">

    <!-- WindowChrome enables custom title bar while keeping normal resize + caption behavior -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="7"
                            CornerRadius="10"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground"
            Value="{DynamicResource MaterialDesignBody}" />
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground"
            Value="{DynamicResource MaterialDesignBody}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground"
            Value="{DynamicResource MaterialDesignBody}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground"
            Value="{DynamicResource MaterialDesignBody}" />
        </Style>
        

        <!-- =========================================================
             Caption button hover/pressed brushes (NO hex-with-alpha in triggers)
             ========================================================= -->

        <!-- Subtle hover/pressed for minimize/max/restore -->
        <SolidColorBrush x:Key="CaptionHoverBrush"   Color="#268A8A8A"/>
        <SolidColorBrush x:Key="CaptionPressedBrush" Color="#30909090"/>

        <!-- Close button hover/pressed (Windows-like) -->
        <SolidColorBrush x:Key="CaptionCloseHoverBrush"   Color="#E81123"/>
        <SolidColorBrush x:Key="CaptionClosePressedBrush" Color="#C50F1F"/>

        <!-- =========================================================
             Caption Buttons
             ========================================================= -->

        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <!-- Important: keep arrow cursor, not hand -->
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg"
                                        Property="Background"
                                        Value="{StaticResource CaptionHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg"
                                        Property="Background"
                                        Value="{StaticResource CaptionPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CaptionCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource CaptionButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg"
                                        Property="Background"
                                        Value="{StaticResource CaptionCloseHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg"
                                        Property="Background"
                                        Value="{StaticResource CaptionClosePressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- =========================
             TITLE BAR
             ========================= -->
        <Border Grid.Row="0"
                Background="#1F262A"
                BorderBrush="#2E363B"
                BorderThickness="0,0,0,1">

            <!-- mouse down allows drag/move (code-behind handles double click to maximize) -->
            <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App mark -->
                <Image Width="64"
                       Height="64"
                       Margin="0,0,0,0"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Source="pack://application:,,,/Resources/castara_logo_64.png"/>

                <!-- App title -->
                <TextBlock Grid.Column="1"
                           Text="CASTARA"
                           FontSize="17"
                           FontWeight="ExtraBold"
                           VerticalAlignment="Center"
                           Foreground="#F0F0F0"/>

                <!-- Caption buttons -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">

                    <Button Style="{StaticResource CaptionButtonStyle}"
                            Click="Minimize_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <materialDesign:PackIcon Kind="WindowMinimize"
                                                 Width="18"
                                                 Height="18"
                                                 Foreground="#D0D0D0"/>
                    </Button>

                    <Button Style="{StaticResource CaptionButtonStyle}"
                            Click="MaxRestore_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <materialDesign:PackIcon x:Name="MaxRestoreIcon"
                                                 Kind="WindowMaximize"
                                                 Width="18"
                                                 Height="18"
                                                 Foreground="#D0D0D0"/>
                    </Button>

                    <Button Style="{StaticResource CaptionCloseButtonStyle}"
                            Click="Close_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <materialDesign:PackIcon Kind="WindowClose"
                                                 Width="18"
                                                 Height="18"
                                                 Foreground="#D0D0D0"/>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <!-- =========================
             TOP TOOLBAR (Light/Dark toggle)
             ========================= -->
        <materialDesign:ColorZone Grid.Row="1"
                                  Mode="PrimaryDark"
                                  Padding="16">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Workbench"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Opacity="0.9"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <TextBlock Text="Light"
                               Foreground="#F0F0F0"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Opacity="0.9"/>

                    <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  IsChecked="{Binding IsDarkMode}"
                                  VerticalAlignment="Center"/>

                    <TextBlock Text="Dark"
                               Foreground="#F0F0F0"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Opacity="0.9"/>
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>

        <!-- =========================
             CONTENT
             ========================= -->
        <Grid Grid.Row="2" Margin="20">
            <ContentControl Content="{Binding CurrentView}"/>
        </Grid>

        <!-- =========================
             STATUS BAR (anchored bottom)
             ========================= -->
        <Border Grid.Row="3"
                Height="36"
                Padding="12,6"
                BorderBrush="#0B0E10"
                BorderThickness="0,1,0,0">

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1A2024" Offset="0"/>
                    <GradientStop Color="#14181B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusLeftText}"
                           Foreground="#D6D6D6"
                           VerticalAlignment="Center"/>

                <Border Grid.Column="1"
                        CornerRadius="14"
                        Padding="10,4"
                        Background="#0F1316"
                        BorderBrush="#2A2A2A"
                        BorderThickness="1"
                        VerticalAlignment="Center">

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Circle"
                                                 Width="12"
                                                 Height="12"
                                                 Margin="0,0,8,0"
                                                 Foreground="{Binding StatusBrush}"/>

                        <TextBlock Text="{Binding StatusRightText}"
                                   Foreground="#D6D6D6"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

    </Grid>
</Window>