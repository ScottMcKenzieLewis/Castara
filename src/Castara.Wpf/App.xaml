<Application x:Class="Castara.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:Castara.Wpf.Infrastructure.Converters"
             xmlns:vm="clr-namespace:Castara.Wpf.ViewModels"
             xmlns:views="clr-namespace:Castara.Wpf.Views">

    <Application.Resources>
        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>

                <!-- Material Design 3 defaults (required) -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />

                <!-- Component dictionaries you actually use -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Button.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.TextBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ComboBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ToggleButton.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Card.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ListBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ScrollViewer.xaml" />

                <!-- Your bundled theme (this sets initial base + primary/secondary) -->
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="BlueGrey"
                                             SecondaryColor="Amber" />

            </ResourceDictionary.MergedDictionaries>
            
            <!-- Map CalculationsViewModel -> CalculationsView -->
            <DataTemplate DataType="{x:Type vm:CalculationsViewModel}">
                <views:CalculationsView />
            </DataTemplate>

            <conv:FirstValidationErrorConverter x:Key="FirstValidationErrorConverter"/>

            <Style x:Key="ValidatedTextBox"
              TargetType="TextBox"
              BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">

                <Style.Triggers>
                    <Trigger Property="Validation.HasError"
                        Value="True">

                        <Setter Property="BorderBrush"
                           Value="#E53935"/>

                        <Setter Property="BorderThickness"
                           Value="2"/>

                        <Setter Property="ToolTip"
                           Value="{Binding RelativeSource={RelativeSource Self},
                                           Path=(Validation.Errors)[0].ErrorContent}"/>
                    </Trigger>
                    <Trigger Property="Validation.HasError" Value="False">
                        <Setter Property="ToolTip" Value="{x:Null}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

         <Style x:Key="ValidatedTextBoxSafeTooltip"
          TargetType="TextBox"
          BasedOn="{StaticResource ValidatedTextBox}">
                <Style.Triggers>
                    <Trigger Property="Validation.HasError" Value="True">
                        <Setter Property="ToolTip"
                       Value="{Binding RelativeSource={RelativeSource Self},
                                       Path=(Validation.Errors),
                                       Converter={StaticResource FirstValidationErrorConverter}}"/>
                    </Trigger>
                    <Trigger Property="Validation.HasError" Value="False">
                        <Setter Property="ToolTip" Value="{x:Null}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

        </ResourceDictionary>

 
    </Application.Resources>
</Application>